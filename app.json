{
  "expo": {
    "name": "AutoPortal",
    "slug": "AutoPortal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.AutozoneItla"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-image-picker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir acceso a fotos para cambiar perfil",
          "cameraPermission": "Permitir usar la cámara para foto de perfil"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "cc41ad38-8be3-4706-aa5e-0b5c7c117494"
      }
    }
  }
}
